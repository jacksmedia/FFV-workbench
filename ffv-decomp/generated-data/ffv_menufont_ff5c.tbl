A6=ro
A7=te
A8=le
A9=el
AA=`
AB=~
AC=if
AD=lt
AE=tl
AF=ir
B0=tt

; -- $B1-$BB  Additional ligatures / icons (ff5c) ----------------------------[I/?]
; RPGe stored katakana diacritic modifiers here (unused in English).
; ff5c repurposes all 11 slots. Identified via tile image analysis:
;   $B1=ie, $B2=in confirmed as text ligatures.
;   $B3 (symmetric Y+arcs), $B5 (circle+3-bump) likely ou/ow ligatures.
;   $B4 (wizard-hat shape), $B6 (diagonal stripes), $B7 (thin sword) unclear --
;     may be icons or unusual ligatures; needs author verification.
;   $B8 = dark fill (blank/padding).
;   $B9, $BB shapes unclear; $BA (twin ovals) likely oo.
B1=ie
B2=in
B3=[Mail]
B4=[Hat]
B5=[Helm]
B6=[KSwd]
B7=[NSwd]
B8=[B8]
B9=la
BA=oi
BB=er


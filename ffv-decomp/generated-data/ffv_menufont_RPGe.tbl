93=z

; ── $94–$B0  Kerning ligature tiles ──────────────────────────────────────── [P]
; RPGe packed common letter pairs as single 8×8 tiles for tighter text layout.
; These appear as narrow/combined glyphs in Tile Molester after lowercase z.
94=il
95=it
96=[96]
97=li
98=ll
99='
9A="
9B=:
9C=;
9D=,
9E=(
9F=)
A0=/
A1=!
A2=?
A3=.
A4=ti
A5=fi
A6=[A6]
A7=[A7]
A8=[A8]
A9=[A9]
AA=`
AB=~
AC=if
AD=lt
AE=tl
AF=ir
B0=tt

; ── $B1–$BB  Japanese Scripts ─────────────────────────────────────────────────────── [?]
B1=[B1]

72=S
73=T
74=U
75=V
76=W
77=X
78=Y
79=Z

; ── $7A–$7F  Lowercase a–f ────────────────────────────────────────────────── [P]
7A=a
7B=b
7C=c
7D=d
7E=e
7F=f

; ── $80–$8F  Lowercase g–v ────────────────────────────────────────────────── [P]

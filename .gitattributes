# Auto detect text files and normalize to LF in repo
* text=auto eol=lf

# Force these to always be LF (even on Windows checkout)
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files - don't touch
*.png binary
*.gif binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
